+		// Pulls the conform driver from the workspace/stream definitions. Empty means the agent runs the standard JobDriver.
+		static string? GetConformDriver(IAgent agent, BuildConfig buildConfig)
+		{
+			foreach (StreamConfig stream in buildConfig.Streams)
+			{
+				if (!stream.AgentTypes.Values.Any(agentType => agent.IsInPool(agentType.Pool)))
+				{
+					continue;
+				}
+				if (!String.IsNullOrEmpty(stream.JobOptions.Driver))
+				{
+					return stream.JobOptions.Driver;
+				}
+				string? templateDriver = stream.Templates.Select(template => template.JobOptions.Driver).FirstOrDefault(driver => !String.IsNullOrEmpty(driver));
+				if (!String.IsNullOrEmpty(templateDriver))
+				{
+					return templateDriver;
+				}
+			}
+			return null;
+		}
