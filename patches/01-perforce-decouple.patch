+		/// <summary>
+		/// Whether a workspace needs a Perforce server, based on its materializer.
+		/// Workspaces with no materializer name, or the built-in Perforce / ManagedWorkspace materializers, are Perforce-backed. 
+		/// Any other named materializer (eg. a non-Perforce VCS provider) does not need Perforce.
+		/// </summary>
+		public static bool RequiresPerforce(string? method)
+		{
+			string? name = GetMaterializerName(method);
+			return String.IsNullOrEmpty(name)
+				|| name.Equals("Perforce", StringComparison.OrdinalIgnoreCase)
+				|| name.Equals("ManagedWorkspace", StringComparison.OrdinalIgnoreCase);
+		}
+
+		/// <summary>
+		/// Adds an agent workspace message for a non-Perforce VCS - no Perforce server selection or credentials.
+		/// A registered IWorkspaceMessageEnricher (from the VCS provider plugin) fills in the provider-specific fields.
+		/// </summary>
+		public static void AddWorkspaceMessage(this AgentWorkspaceInfo workspace, IList<RpcAgentWorkspace> workspaceMessages)
+		{
+			RpcAgentWorkspace result = new RpcAgentWorkspace
+			{
+				ConfiguredCluster = workspace.Cluster,
+				ConfiguredUserName = workspace.UserName,
+				Cluster = workspace.Cluster ?? String.Empty,
+				UserName = workspace.UserName,
+				Identifier = workspace.Identifier,
+				Stream = workspace.Stream,
+				Incremental = workspace.Incremental,
+				Method = workspace.Method ?? String.Empty,
+				MinScratchSpace = workspace.MinScratchSpace ?? 0,
+				ConformDiskFreeSpace = workspace.ConformDiskFreeSpace ?? 0,
+			};
+
+			if (workspace.View != null)
+			{
+				result.View.AddRange(workspace.View);
+			}
+
+			workspaceMessages.Add(result);
+		}
+
+		// Parses the "name" materializer key out of a workspace method query string (eg. "name=lore&branch=main").
+		static string? GetMaterializerName(string? method)
+		{
+			if (String.IsNullOrEmpty(method))
+			{
+				return null;
+			}
+			foreach (string pair in method.Split('&', StringSplitOptions.RemoveEmptyEntries))
+			{
+				int equals = pair.IndexOf('=', StringComparison.Ordinal);
+				if (equals > 0 && pair[..equals].Trim().Equals("name", StringComparison.OrdinalIgnoreCase))
+				{
+					return pair[(equals + 1)..].Trim();
+				}
+			}
+			return null;
+		}
+
