+			{
+				if (String.Equals(cluster.Name, entry.Cluster, StringComparison.OrdinalIgnoreCase))
+				{
+					return cluster.Servers.Any(server => server.AssumeHealthy && String.Equals(server.ServerAndPort, entry.BaseServerAndPort, StringComparison.OrdinalIgnoreCase));
